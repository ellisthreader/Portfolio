{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "tsc --noEmit && vite build",
        "dev": "vite",
        "typecheck": "tsc --noEmit",
        "preview": "vite preview",
        "serve": "php artisan serve --host=localhost --port=8000",
        "dev:full": "concurrently -n laravel,vite -c blue,green \"npm run serve\" \"npm run dev -- --host localhost --port 5173\""
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "@types/react": "^18.3.28",
        "@types/react-dom": "^18.3.7",
        "@vitejs/plugin-react": "^5.2.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.1.0",
        "tailwindcss": "^3.4.19",
        "vite": "^7.0.7"
    },
    "dependencies": {
        "@inertiajs/react": "^2.3.18",
        "@react-three/drei": "^9.122.0",
        "@react-three/fiber": "^8.18.0",
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/typography": "^0.5.19",
        "autoprefixer": "^10.4.27",
        "fbx2gltf": "^0.9.7-p1",
        "laravel-echo": "^2.3.1",
        "postcss": "^8.5.8",
        "pusher-js": "^8.4.0",
        "react": "18.3",
        "react-dom": "18.3",
        "three": "0.167.1",
        "typescript": "^5.9.3",
        "ziggy-js": "^2.6.2"
    }
}
